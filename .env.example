# OpenAI API
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google AI (Gemini)
GOOGLE_API_KEY=your_google_api_key

# Mistral AI
MISTRAL_API_KEY=your_mistral_api_key

# Groq
GROQ_API_KEY=your_groq_api_key

# Custom (any OpenAI-compatible endpoint)
# Use this for Ollama, LM Studio, OpenRouter, an Azure OpenAI deployment, or any self-hosted compatible API.
#   Ollama:    CUSTOM_BASE_URL=http://localhost:11434/v1
#   LM Studio: CUSTOM_BASE_URL=http://localhost:1234/v1
CUSTOM_API_KEY=your_custom_api_key
CUSTOM_BASE_URL=http://localhost:11434/v1
CUSTOM_MODEL_NAME=your_custom_model_name

# LangSmith (optional - for tracing)
LANGCHAIN_API_KEY=your_langchain_api_key
